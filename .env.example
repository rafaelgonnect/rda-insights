# App auth (HTTP Basic Auth — single user)
APP_USERNAME=admin
APP_PASSWORD=

# OpenRouter (https://openrouter.ai/keys) — LLM gateway.
OPENROUTER_API_KEY=
# Model slug — see https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Superset — public URL (used by the iframe loaded in the browser)
SUPERSET_URL=
# Optional: internal Docker hostname for backend REST API calls.
# Falls back to SUPERSET_URL if unset.
SUPERSET_INTERNAL_URL=
# Backend uses these to log in to Superset's REST API.
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=

# Comma-separated origins allowed to embed Superset dashboards. Used when
# the backend auto-bootstraps a dashboard's embedded UUID. Leave empty to
# accept any embedder origin (still requires a valid guest token).
EMBED_ALLOWED_DOMAINS=

# Redis — pick a DB index that Superset doesn't use (Superset uses 0 and 1)
REDIS_URL=

# Approximate monthly LLM spend cap (USD)
MAX_USD_MONTH=20
