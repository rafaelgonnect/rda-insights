# App auth (HTTP Basic Auth — single user)
APP_USERNAME=admin
APP_PASSWORD=

# OpenRouter (https://openrouter.ai/keys) — LLM gateway.
# OpenRouter is OpenAI-compatible and routes to Anthropic/OpenAI/Google models.
OPENROUTER_API_KEY=
# Model slug — see https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Superset MCP (SIP-187 / FastMCP). Use the internal Docker hostname when this
# app runs as a sibling in the same Docker network as superset-mcp, OR the
# public HTTPS URL when running outside that network.
MCP_INTERNAL_URL=
MCP_JWT_SECRET=
MCP_JWT_ISSUER=claude-code-user
MCP_JWT_AUDIENCE=superset-mcp

# Superset (for iframe embed) — public HTTPS URL of your Superset instance.
SUPERSET_URL=

# Redis — shared with the Superset stack; pick a DB index that Superset
# doesn't use (Superset uses 0 and 1 by default).
REDIS_URL=

# Approximate monthly LLM spend cap (USD). Check OpenRouter dashboard for
# authoritative spend.
MAX_USD_MONTH=20
