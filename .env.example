# App auth (HTTP Basic Auth — single user)
APP_USERNAME=admin
APP_PASSWORD=

# OpenRouter (https://openrouter.ai/keys) — used as LLM gateway.
# OpenRouter is OpenAI-compatible and routes to Anthropic/OpenAI/Google models.
OPENROUTER_API_KEY=
# Model slug — see https://openrouter.ai/models
# Examples: anthropic/claude-sonnet-4.5, openai/gpt-4o, google/gemini-2.5-pro
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Superset MCP (shared with superset-stack)
MCP_INTERNAL_URL=http://superset-mcp:5008
MCP_JWT_SECRET=
MCP_JWT_ISSUER=claude-code-user
MCP_JWT_AUDIENCE=superset-mcp

# Superset (for iframe embed)
SUPERSET_URL=https://melanibotto-rdasuperset.bdoje9.easypanel.host

# Redis (shared with superset-stack)
REDIS_URL=redis://redis:6379/2

# Cost cap (USD per calendar month, approximated client-side; check OpenRouter
# dashboard for the authoritative spend)
MAX_USD_MONTH=20
